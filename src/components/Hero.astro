---
import { ACQUISITION_MAILTO, cfImageUrl, CF_IMAGES } from '../config/site';

const heroImage = cfImageUrl(CF_IMAGES.heroImageId);
---

<header class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Fixed parallax background image -->
  <div
    class="fixed inset-0 z-0"
    style={`
      background-image: url('${heroImage}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    `}
    aria-hidden="true"
  ></div>
  <!-- Subtle overlay for text readability -->
  <div class="fixed inset-0 z-[1] bg-gradient-to-b from-black/30 via-black/15 to-[#F8F1E9]/90" aria-hidden="true"></div>

  <div class="relative z-[2] max-w-5xl mx-auto px-6 py-20 text-center">
    <!-- Premium .com Badge -->
    <div class="inline-flex items-center gap-x-2 mb-6">
      <div class="com-badge flex items-center gap-x-2 px-4 py-1.5 rounded-2xl text-sm font-bold tracking-[1px]">
        <i class="fa-solid fa-globe fa-sm"></i>
        <span>THE ULTIMATE .COM</span>
      </div>
    </div>

    <h1 class="domain-name tracking-tighter mb-3">waxphx.com</h1>

    <p class="max-w-2xl mx-auto text-2xl md:text-3xl font-semibold tracking-tight text-[#4A5D4A] mb-6">
      The definitive .com for<br class="hidden md:block" /> Phoenix waxing &amp; hair removal.
    </p>

    <p class="max-w-lg mx-auto text-lg text-[#5C5C5C] mb-10">
      Short. Memorable. Highest-trust TLD. The single best digital asset for dominating the Phoenix beauty market.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#acquire"
        class="group inline-flex items-center justify-center gap-x-3 w-full sm:w-auto px-9 py-4 bg-[#B85C38] hover:bg-[#A04E30] text-white font-semibold text-lg rounded-3xl transition-all active:scale-[0.985] shadow-lg shadow-[#B85C38]/20"
      >
        <span>Inquire to Acquire</span>
        <i class="fa-solid fa-arrow-right group-hover:translate-x-0.5 transition-transform"></i>
      </a>

      <a
        href="#why"
        class="inline-flex items-center justify-center w-full sm:w-auto px-8 py-4 border border-[#D4C9B8] hover:bg-white text-[#4A5D4A] font-semibold text-lg rounded-3xl transition-all"
      >
        Why This .com Wins
      </a>
    </div>

    <div class="mt-8 flex items-center justify-center gap-x-6 text-sm text-white/80">
      <div class="flex items-center gap-x-1.5">
        <i class="fa-solid fa-check text-[#B85C38]"></i>
        <span>Exact-match keywords</span>
      </div>
      <div class="flex items-center gap-x-1.5">
        <i class="fa-solid fa-check text-[#B85C38]"></i>
        <span>Maximum brand equity</span>
      </div>
      <div class="flex items-center gap-x-1.5">
        <i class="fa-solid fa-check text-[#B85C38]"></i>
        <span>Premium resale value</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-12 animate-bounce">
      <a href="#why" class="inline-flex flex-col items-center gap-y-2 text-white/60 hover:text-white transition-colors">
        <span class="text-xs uppercase tracking-[3px] font-semibold">Scroll</span>
        <i class="fa-solid fa-chevron-down"></i>
      </a>
    </div>
  </div>

  <div class="fixed bottom-0 left-1/2 -translate-x-1/2 w-[800px] h-[1px] bg-gradient-to-r from-transparent via-white/20 to-transparent z-[2]"></div>
</header>
