---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — waxphx.com"
  description="The page you requested could not be found."
  noindex={true}
>
  <main class="min-h-screen flex items-center justify-center bg-[#F8F1E9]">
    <div class="text-center px-6">
      <div class="text-8xl font-display text-[#B85C38] mb-4">404</div>
      <h1 class="text-2xl font-semibold text-[#2D2D2D] mb-4">Page Not Found</h1>
      <p class="text-[#5C5C5C] mb-8 max-w-md">The page you're looking for doesn't exist. Return to the homepage to learn about waxphx.com domain acquisition.</p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-8 py-3 bg-[#B85C38] hover:bg-[#A04E30] text-white font-semibold rounded-2xl transition-all"
      >
        Back to Homepage
      </a>
    </div>
  </main>
</BaseLayout>
